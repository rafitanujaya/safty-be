generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  username  String
  email     String   @unique
  avatarUrl String?
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  googleAccounts GoogleAccount[]
  settings       ProtectionSettings?
  threatEvents   ThreatEvent[]
  fileScans      FileScan[]
  imageScans     ImageScan[]
}

model GoogleAccount {
  id           String   @id @default(cuid())
  userId       String   @unique
  googleUserId String   @unique
  email        String   @unique
  name         String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProtectionSettings {
  id                  String          @id @default(cuid())
  userId              String          @unique
  realtimeProtection  Boolean         @default(true)
  formBlocking        Boolean         @default(true)
  downloadScanning    Boolean         @default(true)
  trackerBlocking     Boolean         @default(true)
  redirectProtection  Boolean         @default(true)
  riskThreshold       Int             @default(65)
  themePreference     ThemePreference @default(SYSTEM)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ThreatCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events ThreatEvent[]
}

model ThreatSource {
  id         String   @id @default(cuid())
  domain     String   @unique
  reputation Int      @default(100)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  events ThreatEvent[]

  @@index([domain])
}

model ThreatEvent {
  id          String          @id @default(cuid())
  userId      String
  categoryId  String?
  sourceId    String?

  eventType   ThreatEventType
  riskLevel   RiskLevel       @default(LOW)
  riskScore   Int             @default(0)
  actionTaken ActionTaken     @default(LOGGED)
  status      EventStatus     @default(ACTIVE)

  domain      String?
  pageUrl     String?
  message     String?

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ThreatCategory? @relation(fields: [categoryId], references: [id])
  source   ThreatSource?   @relation(fields: [sourceId], references: [id])

  @@index([userId])
  @@index([eventType])
  @@index([riskLevel])
  @@index([actionTaken])
  @@index([createdAt])
}

model FileScan {
  id            String      @id @default(cuid())
  userId        String

  fileName      String
  fileType      String?
  fileSize      Int?
  riskScore     Int         @default(0)
  riskLevel     RiskLevel   @default(LOW)
  verdict       ScanVerdict @default(SAFE)
  detectionNote String?
  actionTaken   ActionTaken @default(LOGGED)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([verdict])
  @@index([riskLevel])
  @@index([createdAt])
}

model ImageScan {
  id            String      @id @default(cuid())
  userId        String

  imageName     String
  imageType     String?
  fileSize      Int?
  riskScore     Int         @default(0)
  riskLevel     RiskLevel   @default(LOW)
  verdict       ScanVerdict @default(SAFE)
  confidence    Float?
  detectionNote String?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([verdict])
  @@index([riskLevel])
  @@index([createdAt])
}

model ScamEducationContent {
  id                String           @id @default(cuid())
  title             String
  summary           String?
  content           String?
  category          String
  readTime          String?
  imageUrl          String?
  difficulty        Difficulty       @default(BEGINNER)
  relatedThreatType ThreatEventType?

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([category])
}

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
}

enum RiskLevel {
  SAFE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ThreatEventType {
  PHISHING_PREVENTED
  BLOCKED_DOWNLOAD
  FORM_BLOCKED
  TRACKER_BLOCKED
  BACKGROUND_SCAN
  MALICIOUS_REDIRECT
  SUSPICIOUS_INTERACTION
  FILE_SCAN
  IMAGE_SCAN
}

enum ActionTaken {
  BLOCKED
  WARNING
  PASSED
  QUARANTINED
  LOGGED
}

enum EventStatus {
  ACTIVE
  RESOLVED
  IGNORED
}

enum ScanVerdict {
  SAFE
  SUSPICIOUS
  MALICIOUS
  SCAM
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}